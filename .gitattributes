# Normalisation des fins de ligne pour le projet AirSentinel
# Git convertit automatiquement LF <-> CRLF selon la plateforme

# Fichiers texte : LF dans le dépôt, conversion auto sur checkout
* text=auto

# Python : forcer LF
*.py text eol=lf

# TypeScript / JavaScript / JSON
*.ts  text eol=lf
*.tsx text eol=lf
*.js  text eol=lf
*.jsx text eol=lf
*.json text eol=lf

# CSS / HTML
*.css  text eol=lf
*.html text eol=lf

# Config files
*.env      text eol=lf
*.toml     text eol=lf
*.yaml     text eol=lf
*.yml      text eol=lf
*.md       text eol=lf
*.txt      text eol=lf

# Fichiers binaires : pas de conversion
*.png  binary
*.jpg  binary
*.jpeg binary
*.webp binary
*.ico  binary
*.pdf  binary
*.parquet binary
*.pkl  binary
*.joblib binary
